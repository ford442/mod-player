{
  "name": "react-libopenmpt-viewer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:shaders": "node scripts/sync-shaders.mjs",
    "predev": "npm run sync:shaders",
    "dev": "vite",
    "prebuild": "npm run sync:shaders",
    "build:worklet": "bash ./build-wasm.sh",
    "build:emcc": "bash scripts/build-wasm.sh",
    "build": "tsc && node --max-old-space-size=4096 node_modules/.bin/vite build",
    "build:xm-player": "VITE_APP_BASE_PATH=/xm-player/ npm run build",
    "verify:build": "node scripts/verify-build.mjs",
    "build:xm-player:verify": "npm run build:xm-player && npm run verify:build",
    "preview": "vite preview",
    "lint": "exit 0",
    "typecheck": "tsc --noEmit",
    "test:duration-parity": "node utils/__debug__/durationParity.test.cjs",
    "test:trigger-tail": "node utils/__debug__/triggerTailPacking.test.cjs",
    "test:shader-registry": "node utils/__debug__/shaderRegistry.test.cjs",
    "test:circular-paging": "node utils/__debug__/circularPaging.test.cjs",
    "capture:trigger-tail": "node scripts/capture-trigger-tail.mjs",
    "capture:v046-paging": "node scripts/capture-v046-paging.mjs",
    "audit:shader-modes": "node scripts/audit-shader-modes.mjs",
    "screenshot:shaders": "node scripts/screenshot-shader-check.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-query": "^5.100.14",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.160.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@webgpu/types": "^0.1.40",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.22.0",
    "vite": "^5.2.11"
  }
}
